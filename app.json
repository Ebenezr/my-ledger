{
  "expo": {
    "name": "my-ledger",
    "slug": "my-ledger",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "myledger",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon",
      "bundleIdentifier": "com.ebukosia.myledger",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "predictiveBackGestureEnabled": false,
      "package": "com.ebukosia.myledger"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "./plugins/with-android-workmanager-resolution",
      [
        "expo-widgets",
        {
          "bundleIdentifier": "com.ebukosia.myledger.widgets",
          "groupIdentifier": "group.com.ebukosia.myledger",
          "widgets": [
            {
              "name": "TodayWidget",
              "displayName": "Today",
              "description": "Shows today's My-Ledger tasks.",
              "supportedFamilies": [
                "systemMedium",
                "systemLarge"
              ]
            }
          ]
        }
      ],
      [
        "react-native-android-widget",
        {
          "widgets": [
            {
              "name": "Today",
              "label": "Today",
              "description": "Shows today's My-Ledger tasks.",
              "minWidth": "250dp",
              "minHeight": "110dp",
              "targetCellWidth": 4,
              "targetCellHeight": 3,
              "resizeMode": "horizontal|vertical",
              "updatePeriodMillis": 1800000
            }
          ]
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      [
        "@react-native-community/datetimepicker",
        {
          "android": {
            "datePicker": {
              "colorAccent": {
                "light": "#C9491D"
              },
              "colorControlActivated": {
                "light": "#C9491D"
              },
              "colorControlHighlight": {
                "light": "#D7A28F"
              },
              "textColor": {
                "light": "#171717"
              },
              "textColorPrimary": {
                "light": "#171717"
              },
              "textColorSecondary": {
                "light": "#67645E"
              },
              "windowBackground": {
                "light": "#DEDDD9"
              }
            }
          }
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#ffffff",
          "defaultChannel": "default",
          "enableBackgroundRemoteNotifications": false
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "02b77f96-8ee2-4226-8bda-d53d38273118"
      }
    },
    "owner": "ebukosia"
  }
}
